# ============================================================
# Traffic Phantom - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For GitHub Actions: these are set via workflow_dispatch inputs
# or repository secrets. See README.md for details.
# ============================================================

# REQUIRED - Your OpenRouter API key (get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Your site name (used as X-Title header for OpenRouter requests)
SITE_NAME=My Awesome Blog

# Your site URL (used as HTTP-Referer for OpenRouter + posted in comment URL fields)
SITE_URL=https://example.com

# Name to use when posting comments on target sites
COMMENT_AUTHOR=YourName

# Email to use when posting comments on target sites
COMMENT_EMAIL=you@example.com
